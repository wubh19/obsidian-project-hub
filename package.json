{
  "name": "obsidian-project-hub",
  "version": "0.4.19",
  "private": true,
  "description": "Obsidian plugin for project, version, and task management with Markdown and YAML.",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "deploy:obsidian": "node scripts/deploy-obsidian.mjs",
    "release:check": "node scripts/check-release.mjs",
    "release": "npm run build && npm run release:check && npm run deploy:obsidian"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.1",
    "obsidian": "latest",
    "typescript": "^5.8.2"
  }
}
